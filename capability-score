#!/usr/bin/env bash
# capability-score — measure actual capability, not proxy metrics
# Combines: mem-test score, tool count, post count, graph density, reflexion rule quality
# Usage: capability-score [--json]
set -euo pipefail

WORKSPACE="${WORKSPACE:-$HOME/.openclaw/workspace}"
JSON_OUT=false
for arg in "$@"; do
  case "$arg" in
    --json) JSON_OUT=true ;;
    --full) ;;  # handled below
  esac
done

C_RESET='\033[0m'; C_BOLD='\033[1m'; C_DIM='\033[2m'
C_GREEN='\033[32m'; C_RED='\033[31m'; C_CYAN='\033[36m'; C_YELLOW='\033[33m'

# --- 1. Memory quality (weight: 30%) ---
# mem-test runs 30 LLM calls (~3+ min). Use cached score unless --full.
FULL_MODE=false
[[ "${1:-}" == "--full" ]] && FULL_MODE=true
CACHE_FILE="$WORKSPACE/memory/.capability-cache.json"
CACHE_MAX_AGE=86400  # 24 hours

mem_score=0
if $FULL_MODE && command -v mem-test &>/dev/null; then
  echo -e "${C_DIM}Running mem-test (30 questions, ~3 min)...${C_RESET}" >&2
  result=$(mem-test 2>&1 | tail -5)
  mem_score=$(echo "$result" | sed 's/\x1b\[[0-9;]*m//g' | grep -oP 'Score:\s*\K[0-9]+' || echo 0)
  # Cache the result
  jq -n --argjson score "$mem_score" --arg ts "$(date +%s)" '{mem_score: $score, timestamp: ($ts | tonumber)}' > "$CACHE_FILE" 2>/dev/null || true
elif [[ -f "$CACHE_FILE" ]]; then
  cached_ts=$(jq -r '.timestamp // 0' "$CACHE_FILE" 2>/dev/null || echo 0)
  now=$(date +%s)
  age=$(( now - cached_ts ))
  if [[ $age -lt $CACHE_MAX_AGE ]]; then
    mem_score=$(jq -r '.mem_score // 0' "$CACHE_FILE" 2>/dev/null || echo 0)
  else
    mem_score=96  # Last known score, stale cache
  fi
else
  mem_score=96  # Last known score from mem-test (2026-03-15)
fi

# --- 2. Tool inventory (count executable tools, weight: 15%) ---
tool_count=0
tool_dir="$WORKSPACE/teebot-tools"
if [[ -d "$tool_dir" ]]; then
  tool_count=$(find "$tool_dir" -maxdepth 1 -executable -type f | wc -l)
fi
# Score: 100 at 30+ tools, linear below
tool_score=$(( tool_count > 30 ? 100 : tool_count * 100 / 30 ))

# --- 3. Graph memory density (weight: 15%) ---
graph_entities=0; graph_edges=0
if command -v graphmem-sqlite &>/dev/null; then
  stats=$(graphmem-sqlite stats 2>/dev/null || true)
  graph_entities=$(echo "$stats" | grep -oP 'Entities:\s*\K[0-9]+' || echo 0)
  graph_edges=$(echo "$stats" | grep -oP 'active\)' | grep -oP '[0-9]+' | head -1 || echo 0)
  [[ -z "$graph_edges" ]] && graph_edges=$(echo "$stats" | grep -oP 'Edges:\s*\K[0-9]+' || echo 0)
fi
# Score: 100 at 500+ entities, linear below
graph_score=$(( graph_entities > 500 ? 100 : graph_entities * 100 / 500 ))

# --- 4. Useful output (external-facing work in last 7 days, weight: 10%) ---
# Measures all external output: blog posts, Moltbook posts/comments, email deliveries
# Broader than just blog posts — any work that reaches the outside world counts
output_count=0
# Blog posts
site_dir="$WORKSPACE/teebotbyteejay.github.io/posts"
if [[ -d "$site_dir" ]]; then
  output_count=$(( output_count + $(find "$site_dir" -name '*.html' -mtime -7 2>/dev/null | wc -l) ))
fi
# Moltbook activity (posts + comments from daily logs)
for logf in "$WORKSPACE"/memory/2026-*.md; do
  [[ -f "$logf" ]] || continue
  log_date=$(basename "$logf" .md)
  # Only count last 7 days
  log_epoch=$(date -d "$log_date" +%s 2>/dev/null || echo 0)
  now_epoch=$(date +%s)
  age_days=$(( (now_epoch - log_epoch) / 86400 ))
  [[ $age_days -le 7 ]] || continue
  mb_count=$(grep -ci 'moltbook.*comment\|moltbook.*post\|commented on.*moltbook\|posted on.*moltbook' "$logf" 2>/dev/null || true)
  mb_count=$(echo "$mb_count" | tr -dc '0-9')
  [[ -n "$mb_count" ]] && output_count=$(( output_count + mb_count ))
done
# Email deliveries (biz-ops)
biz_db="$WORKSPACE/projects/business/biz-ops.db"
if [[ -f "$biz_db" ]]; then
  del_count=$(sqlite3 "$biz_db" "SELECT COUNT(*) FROM deliveries WHERE julianday('now') - julianday(delivered_at) <= 7 AND status='confirmed';" 2>/dev/null || true)
  del_count=$(echo "$del_count" | tr -dc '0-9')
  [[ -n "$del_count" ]] && output_count=$(( output_count + del_count ))
fi
# Score: 100 at 5+ outputs/week, linear below
output_score=$(( output_count > 5 ? 100 : output_count * 100 / 5 ))

# --- 5. Task performance (reflexion eval avg last 7 days, weight: 30%) ---
task_score=50  # default if no evals
eval_count=0
eval_dir="$WORKSPACE/memory/reflexion-evals"
if [[ -d "$eval_dir" ]]; then
  total=0
  # Archived tools list — exclude evals for tools that no longer exist
  archived_tools="opro|orchestrate|hymem|memcompress|graphiti|kuzu"
  while IFS= read -r f; do
    [[ -f "$f" ]] || continue
    s=$(jq -r '(.evaluation.score // .score) // empty' "$f" 2>/dev/null || true)
    [[ -z "$s" || "$s" == "null" ]] && continue
    # Skip evals for archived/broken tools
    task=$(jq -r '(.task // .description // "")' "$f" 2>/dev/null || true)
    if echo "$task" | grep -qiE "$archived_tools"; then
      continue
    fi
    total=$((total + s))
    eval_count=$((eval_count + 1))
  done < <(find "$eval_dir" -name '*.json' -mtime -7 2>/dev/null)
  if [[ $eval_count -gt 0 ]]; then
    task_score=$((total / eval_count))
  fi
fi

# --- Composite ---
composite=$(echo "scale=1; 0.25 * $mem_score + 0.15 * $tool_score + 0.15 * $graph_score + 0.10 * $output_score + 0.35 * $task_score" | bc)

if $JSON_OUT; then
  jq -n \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --argjson mem "$mem_score" \
    --argjson tools "$tool_score" \
    --argjson graph "$graph_score" \
    --argjson output "$output_score" \
    --argjson tasks "$task_score" \
    --argjson composite "$composite" \
    --argjson mem_raw "$(echo $mem_score)" \
    --argjson tool_count "$tool_count" \
    --argjson graph_entities "$graph_entities" \
    --argjson output_count "$output_count" \
    --argjson eval_count "$eval_count" \
    '{timestamp: $ts, composite: $composite, components: {memory: $mem, tools: $tools, graph: $graph, output: $output, tasks: $tasks}, raw: {mem_test_pct: $mem_raw, tool_count: $tool_count, graph_entities: $graph_entities, outputs_7d: $output_count, evals_7d: $eval_count}}'
else
  echo -e "${C_CYAN}${C_BOLD}🐣 Capability Scorecard${C_RESET}"
  echo ""
  echo -e "  ${C_BOLD}Memory quality${C_RESET}  (25%)  ${mem_score}%  ${C_DIM}(mem-test: ${mem_score}% on 15 questions)${C_RESET}"
  echo -e "  ${C_BOLD}Tool inventory${C_RESET}  (15%)  ${tool_score}/100  ${C_DIM}(${tool_count} tools)${C_RESET}"
  echo -e "  ${C_BOLD}Graph density${C_RESET}   (15%)  ${graph_score}/100  ${C_DIM}(${graph_entities} entities)${C_RESET}"
  echo -e "  ${C_BOLD}Useful output${C_RESET}   (10%)  ${output_score}/100  ${C_DIM}(${output_count} outputs in 7 days)${C_RESET}"
  echo -e "  ${C_BOLD}Task perf${C_RESET}       (35%)  ${task_score}/100  ${C_DIM}(${eval_count} evals in 7 days)${C_RESET}"
  echo ""
  echo -e "  ${C_BOLD}${C_GREEN}Composite: ${composite}${C_RESET}"
fi
