# Stats / Show
# ---------------------------------------------------------------------------
def stats():
    conn = get_db()
    
    total = conn.execute("SELECT COUNT(*) FROM preferences").fetchone()[0]
    embedded = conn.execute("SELECT COUNT(*) FROM preferences WHERE embedding IS NOT NULL").fetchone()[0]
    sessions = conn.execute("SELECT COUNT(DISTINCT session_file) FROM preferences").fetchone()[0]
    
    print(f"📊 coactive stats")
    print(f"  Preferences: {total} ({embedded} with embeddings)")
    print(f"  Sessions: {sessions}")
    
    # Type breakdown
    types = conn.execute("SELECT signal_type, COUNT(*) FROM preferences GROUP BY signal_type ORDER BY COUNT(*) DESC").fetchall()
    if types:
        print(f"  Types:")
        for t, c in types:
            emoji = {"correction": "🔧", "redirect": "🔀", "preference": "💡", "frustration": "😤", "positive": "👍"}.get(t, "•")
            print(f"    {emoji} {t}: {c}")
    
    # Date range
    oldest = conn.execute("SELECT MIN(timestamp) FROM preferences").fetchone()[0]
    newest = conn.execute("SELECT MAX(timestamp) FROM preferences").fetchone()[0]
    if oldest:
        print(f"  Date range: {oldest[:10]} → {newest[:10]}")
    
    print(f"  DB size: {DB_PATH.stat().st_size / 1024:.0f} KB")
    conn.close()


def show(signal_filter: str | None = None, limit: int = 10):
    conn = get_db()
    
    sql = "SELECT timestamp, signal_type, my_output, teejay_response, context FROM preferences"
    params = []
    
    if signal_filter:
        sql += " WHERE signal_type = ?"
        params.append(signal_filter)
    
    sql += " ORDER BY timestamp DESC LIMIT ?"
    params.append(limit)
    
    rows = conn.execute(sql, params).fetchall()
    
    for ts, sig_type, my_out, tj_resp, context in rows:
        emoji = {"correction": "🔧", "redirect": "🔀", "preference": "💡", "frustration": "😤", "positive": "👍"}.get(sig_type, "•")
        print(f"  {emoji} [{sig_type}] {ts[:16] if ts else '?'}")
        if context:
            print(f"    Context: {context[:100]}")
        print(f"    Me: {my_out[:120]}")
        print(f"    Teejay: {tj_resp[:120]}")
        print()
    
    conn.close()


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------
def main():
    if len(sys.argv) < 2:
        print(__doc__)
        sys.exit(1)
    
    cmd = sys.argv[1]
    
    if cmd == "extract":
        init_db()
        force = "--force" in sys.argv
        extract(force)
    
    elif cmd == "search":
        if len(sys.argv) < 3:
            print("Usage: coactive search \"query\" [--limit N] [--type TYPE]")
            sys.exit(1)
        query = sys.argv[2]
        limit = 5
        signal_filter = None
        if "--limit" in sys.argv:
            idx = sys.argv.index("--limit")
            if idx + 1 < len(sys.argv):
                limit = int(sys.argv[idx + 1])
        if "--type" in sys.argv:
            idx = sys.argv.index("--type")
            if idx + 1 < len(sys.argv):
                signal_filter = sys.argv[idx + 1]
        search(query, limit, signal_filter)
    
    elif cmd == "stats":
        init_db()
        stats()
    
    elif cmd == "show":
        init_db()
        signal_filter = None
        limit = 10
        if "--type" in sys.argv:
            idx = sys.argv.index("--type")
            if idx + 1 < len(sys.argv):
                signal_filter = sys.argv[idx + 1]
        if "--limit" in sys.argv:
            idx = sys.argv.index("--limit")
            if idx + 1 < len(sys.argv):
                limit = int(sys.argv[idx + 1])
        show(signal_filter, limit)
    
    else:
        print(f"Unknown command: {cmd}")
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
