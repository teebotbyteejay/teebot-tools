#!/usr/bin/env bash
# memcompress — compress verbose memory files preserving meaning
# Usage: memcompress <file> [--in-place]
set -euo pipefail

usage() { echo "Usage: memcompress <file.md> [--in-place]"; exit 1; }

[[ $# -lt 1 ]] && usage
FILE="$1"
IN_PLACE=false
[[ "${2:-}" == "--in-place" ]] && IN_PLACE=true
[[ ! -f "$FILE" ]] && { echo "Error: $FILE not found"; exit 1; }

compress() {
  local input="$1"
  
  # Pass 1: Strip boilerplate/filler lines
  sed -E '
    # Remove empty bullet points
    /^[[:space:]]*[-*][[:space:]]*$/d
    # Remove lines that are just "---" separators (keep headings)
    /^[[:space:]]*---[[:space:]]*$/d
    # Remove "nothing else to report" type filler
    /^[[:space:]]*[-*][[:space:]]*(nothing (else )?to (report|note|add)|no (other )?updates?|same as (before|above|yesterday)|continued as before|still the same|no changes?)[[:space:]]*\.?[[:space:]]*$/Id
    # Remove pure filler phrases on their own line
    /^[[:space:]]*[-*][[:space:]]*(overall|in general|basically|essentially|at the end of the day)[,:]?[[:space:]]*$/Id
    # Remove timestamp-only lines (no content after time)
    /^[[:space:]]*[-*][[:space:]]*\d{1,2}:\d{2}[[:space:]]*$/d
  ' "$input" |
  
  # Pass 2: Collapse repeated blank lines
  cat -s |
  
  # Pass 3: Dedup near-identical adjacent lines (normalize and compare)
  awk '
    {
      # Normalize: lowercase, strip leading bullet/whitespace, collapse spaces
      norm = tolower($0)
      gsub(/^[[:space:]]*[-*][[:space:]]*/, "", norm)
      gsub(/[[:space:]]+/, " ", norm)
      gsub(/[[:punct:]]/, "", norm)
      gsub(/^ +| +$/, "", norm)
      
      if (norm == "" || norm != prev_norm) {
        print
      }
      if (norm != "") prev_norm = norm
    }
  ' |
  
  # Pass 4: Merge consecutive date-prefixed lines with same date
  awk '
    /^[[:space:]]*[-*][[:space:]]*[0-9]{4}-[0-9]{2}-[0-9]{2}/ {
      match($0, /[0-9]{4}-[0-9]{2}-[0-9]{2}/)
      date = substr($0, RSTART, RLENGTH)
      # Get content after date
      rest = $0
      sub(/^[[:space:]]*[-*][[:space:]]*[0-9]{4}-[0-9]{2}-[0-9]{2}[[:space:]]*:?[[:space:]]*/, "", rest)
      
      if (date == prev_date && prev_line != "") {
        # Merge with previous
        prev_line = prev_line "; " rest
        next
      } else {
        if (prev_line != "") print prev_line
        prev_date = date
        prev_line = $0
        next
      }
    }
    {
      if (prev_line != "") { print prev_line; prev_line = ""; prev_date = "" }
      print
    }
    END { if (prev_line != "") print prev_line }
  ' |
  
  # Pass 5: Strip trailing whitespace
  sed 's/[[:space:]]*$//'
}

ORIGINAL_SIZE=$(wc -c < "$FILE")
ORIGINAL_LINES=$(wc -l < "$FILE")

RESULT=$(compress "$FILE")
NEW_LINES=$(echo "$RESULT" | wc -l)
NEW_SIZE=$(echo "$RESULT" | wc -c)

if $IN_PLACE; then
  echo "$RESULT" > "$FILE"
  RATIO=$((NEW_SIZE * 100 / ORIGINAL_SIZE))
  echo "📦 Compressed $FILE: ${ORIGINAL_LINES}→${NEW_LINES} lines, ${RATIO}% of original" >&2
else
  echo "$RESULT"
  RATIO=$((NEW_SIZE * 100 / ORIGINAL_SIZE))
  echo "📦 ${ORIGINAL_LINES}→${NEW_LINES} lines, ${RATIO}% of original" >&2
fi
