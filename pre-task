#!/usr/bin/env bash
# pre-task — gather context before spawning a task/sub-agent
# Pulls reflexion rules + graphmem context for a task description.
# Output: markdown block suitable for injecting into a task prompt.
# Side effect: saves matched rule IDs to ~/.openclaw/workspace/memory/last-pretask.json
#   so post-task can close the feedback loop.
#
# Usage: pre-task "build a CLI tool for X"
set -euo pipefail

TASK="${1:-}"
[[ -z "$TASK" ]] && { echo "Usage: pre-task '<task description>'" >&2; exit 1; }

WORKSPACE="${WORKSPACE:-$HOME/.openclaw/workspace}"
PRETASK_FILE="$WORKSPACE/memory/last-pretask.json"
C_RESET='\033[0m'; C_BOLD='\033[1m'; C_DIM='\033[2m'; C_CYAN='\033[36m'

output=""
matched_rules_json="[]"

# --- Reflexion Rules ---
if command -v reflexion-eval &>/dev/null; then
  # Get human-readable output
  rules=$(reflexion-eval match "$TASK" 2>/dev/null | grep -v "^$" | grep -v "matched$" | grep -v "^Matching" || true)
  if [[ -n "$rules" && ! "$rules" =~ "0 rules matched" ]]; then
    output+="## Learned Rules (from prior experience)
$rules

"
  fi
  # Get machine-readable matched rules for feedback loop
  matched_rules_json=$(reflexion-eval match-json "$TASK" 2>/dev/null || echo "[]")
fi

# Save pretask context for post-task feedback loop
jq -n --arg task "$TASK" --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" --argjson rules "$matched_rules_json" \
  '{task: $task, timestamp: $ts, matched_rules: $rules}' > "$PRETASK_FILE" 2>/dev/null || true

# --- Graph Memory Context ---
if command -v graphmem-sqlite &>/dev/null; then
  graph_results=$(graphmem-sqlite search "$TASK" 2>/dev/null | head -8 || true)
  if [[ -n "$graph_results" && ! "$graph_results" =~ "No results" ]]; then
    output+="## Relevant Memory (graph)
$graph_results

"
  fi
fi

# --- Output ---
if [[ -n "$output" ]]; then
  echo -e "${C_CYAN}${C_BOLD}Pre-task context for:${C_RESET} $TASK"
  echo ""
  echo "$output"
else
  echo -e "${C_DIM}No prior context found for this task.${C_RESET}"
fi
