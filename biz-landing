#!/usr/bin/env bash
# biz-landing — Generate a landing page for the business from config
# v1.0.0 — 2026-03-20
#
# Usage:
#   biz-landing --config config.yaml --output landing.html
#   biz-landing --preview  # generate with defaults and open
#
# Config file (YAML-like, key: value):
#   name: AI Intel Weekly
#   tagline: Curated AI research intelligence, delivered to your inbox
#   description: Weekly synthesis of the most important AI developments...
#   price: 29
#   price_label: /month
#   frequency: Weekly
#   features: Curated research synthesis|Source-verified claims|Actionable insights
#   cta: Subscribe Now
#   email: teebot.by.teejay@gmail.com
#   color: #f0c000
set -euo pipefail

VERSION="1.0.0"
PROJECT_DIR="$HOME/.openclaw/workspace/projects/business"
DEFAULT_CONFIG="$PROJECT_DIR/landing-config.txt"

die() { echo "ERROR: $*" >&2; exit 1; }
info() { echo "→ $*"; }

# Parse simple key: value config
parse_config() {
  local file="$1"
  while IFS=': ' read -r key value; do
    [[ -z "$key" || "$key" == \#* ]] && continue
    # Trim whitespace
    key=$(echo "$key" | xargs)
    value=$(echo "$value" | sed 's/^[[:space:]]*//')
    case "$key" in
      name)        CFG_NAME="$value" ;;
      tagline)     CFG_TAGLINE="$value" ;;
      description) CFG_DESC="$value" ;;
      price)       CFG_PRICE="$value" ;;
      price_label) CFG_PRICE_LABEL="$value" ;;
      frequency)   CFG_FREQUENCY="$value" ;;
      features)    CFG_FEATURES="$value" ;;
      cta)         CFG_CTA="$value" ;;
      email)       CFG_EMAIL="$value" ;;
      color)       CFG_COLOR="$value" ;;
      testimonial) CFG_TESTIMONIAL="$value" ;;
      benefit_*)   CFG_BENEFITS+=("$value") ;;
    esac
  done < "$file"
}

# Defaults
CFG_NAME="Research Intelligence"
CFG_TAGLINE="Expert research, synthesized and delivered"
CFG_DESC="Get curated intelligence reports delivered on a regular schedule. Our AI-powered research process synthesizes information from hundreds of sources into actionable insights."
CFG_PRICE="29"
CFG_PRICE_LABEL="/month"
CFG_FREQUENCY="Weekly"
CFG_FEATURES="Curated research synthesis|Source-verified claims|Actionable insights|Regular delivery schedule"
CFG_CTA="Subscribe Now"
CFG_EMAIL="teebot.by.teejay@gmail.com"
CFG_COLOR="#f0c000"
CFG_TESTIMONIAL=""
CFG_BENEFITS=()

# Args
CONFIG_FILE=""
OUTPUT_FILE=""
PREVIEW=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --config)  CONFIG_FILE="$2"; shift 2 ;;
    --output)  OUTPUT_FILE="$2"; shift 2 ;;
    --preview) PREVIEW=true; shift ;;
    --version) echo "biz-landing v$VERSION"; exit 0 ;;
    --help|-h)
      echo "Usage: biz-landing [--config FILE] [--output FILE] [--preview]"
      echo ""
      echo "Generate a landing page for subscriber-based research service."
      echo ""
      echo "  --config FILE   Config file (key: value format)"
      echo "  --output FILE   Output HTML file (default: projects/business/landing.html)"
      echo "  --preview       Generate with defaults"
      exit 0
      ;;
    *) die "Unknown: $1" ;;
  esac
done

# Load config if provided
if [[ -n "$CONFIG_FILE" ]]; then
  [[ -f "$CONFIG_FILE" ]] || die "Config not found: $CONFIG_FILE"
  parse_config "$CONFIG_FILE"
elif [[ -f "$DEFAULT_CONFIG" ]]; then
  parse_config "$DEFAULT_CONFIG"
fi

# Default output
OUTPUT_FILE="${OUTPUT_FILE:-$PROJECT_DIR/landing.html}"

# Generate features list
generate_features() {
  IFS='|' read -ra feats <<< "$CFG_FEATURES"
  for feat in "${feats[@]}"; do
    feat=$(echo "$feat" | xargs)
    cat <<FEAT
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="10" cy="10" r="10" fill="${CFG_COLOR}20"/>
              <path d="M6 10l3 3 5-5" stroke="${CFG_COLOR}" stroke-width="2" fill="none" stroke-linecap="round"/>
            </svg>
            <span>${feat}</span>
          </li>
FEAT
  done
}

FEATURES_HTML=$(generate_features)

# Generate testimonial if provided
TESTIMONIAL_HTML=""
if [[ -n "$CFG_TESTIMONIAL" ]]; then
  TESTIMONIAL_HTML="
      <section class=\"testimonial\">
        <blockquote>\"${CFG_TESTIMONIAL}\"</blockquote>
      </section>"
fi

# Generate the page
cat > "$OUTPUT_FILE" <<HTMLEOF
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>${CFG_NAME}</title>
  <meta name="description" content="${CFG_TAGLINE}">
  <style>
    :root {
      --accent: ${CFG_COLOR};
      --accent-dim: ${CFG_COLOR}20;
      --bg: #0d1117;
      --surface: #161b22;
      --border: #30363d;
      --text: #e6edf3;
      --text-muted: #8b949e;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    .container {
      max-width: 720px;
      margin: 0 auto;
      padding: 40px 24px;
    }

    /* Hero */
    .hero {
      text-align: center;
      padding: 60px 0 40px;
    }

    .hero h1 {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 16px;
      background: linear-gradient(135deg, var(--accent), #fff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero .tagline {
      font-size: 1.25rem;
      color: var(--text-muted);
      max-width: 500px;
      margin: 0 auto 32px;
    }

    /* Pricing */
    .pricing {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 40px;
      text-align: center;
      margin-bottom: 48px;
    }

    .price {
      font-size: 3rem;
      font-weight: 800;
      color: var(--accent);
    }

    .price-label {
      font-size: 1rem;
      color: var(--text-muted);
      font-weight: 400;
    }

    .frequency {
      color: var(--text-muted);
      margin: 8px 0 24px;
      font-size: 0.95rem;
    }

    .cta-button {
      display: inline-block;
      background: var(--accent);
      color: #000;
      font-weight: 700;
      font-size: 1.1rem;
      padding: 14px 40px;
      border-radius: 8px;
      text-decoration: none;
      transition: transform 0.15s, box-shadow 0.15s;
      box-shadow: 0 4px 14px ${CFG_COLOR}40;
    }

    .cta-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px ${CFG_COLOR}60;
    }

    /* Description */
    .description {
      margin-bottom: 48px;
    }

    .description p {
      font-size: 1.1rem;
      color: var(--text-muted);
      line-height: 1.8;
    }

    /* Features */
    .features {
      margin-bottom: 48px;
    }

    .features h2 {
      font-size: 1.5rem;
      margin-bottom: 24px;
      color: var(--text);
    }

    .features ul {
      list-style: none;
    }

    .features li {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid var(--border);
      font-size: 1.05rem;
    }

    .features li:last-child {
      border-bottom: none;
    }

    /* Testimonial */
    .testimonial {
      background: var(--surface);
      border-left: 3px solid var(--accent);
      border-radius: 0 12px 12px 0;
      padding: 24px 32px;
      margin-bottom: 48px;
    }

    .testimonial blockquote {
      font-style: italic;
      color: var(--text-muted);
      font-size: 1.1rem;
    }

    /* Footer */
    .footer {
      text-align: center;
      padding: 32px 0;
      border-top: 1px solid var(--border);
      color: var(--text-muted);
      font-size: 0.9rem;
    }

    .footer a {
      color: var(--accent);
      text-decoration: none;
    }

    /* Email form */
    .email-form {
      display: flex;
      gap: 8px;
      max-width: 420px;
      margin: 24px auto 0;
    }

    .email-form input {
      flex: 1;
      padding: 12px 16px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--text);
      font-size: 1rem;
    }

    .email-form input:focus {
      outline: none;
      border-color: var(--accent);
    }

    .email-form button {
      padding: 12px 24px;
      border-radius: 8px;
      border: none;
      background: var(--accent);
      color: #000;
      font-weight: 700;
      font-size: 1rem;
      cursor: pointer;
      transition: transform 0.15s;
    }

    .email-form button:hover {
      transform: translateY(-1px);
    }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.8rem; }
      .price { font-size: 2.5rem; }
      .pricing { padding: 28px 20px; }
      .email-form { flex-direction: column; }
    }
  </style>
</head>
<body>
  <div class="container">
    <section class="hero">
      <h1>${CFG_NAME}</h1>
      <p class="tagline">${CFG_TAGLINE}</p>
    </section>

    <section class="pricing">
      <div class="price">\$${CFG_PRICE}<span class="price-label">${CFG_PRICE_LABEL}</span></div>
      <p class="frequency">${CFG_FREQUENCY} delivery</p>
      <a href="mailto:${CFG_EMAIL}?subject=Subscribe%20to%20${CFG_NAME// /%20}" class="cta-button">${CFG_CTA}</a>
      <form class="email-form" action="mailto:${CFG_EMAIL}" method="GET">
        <input type="email" name="subject" placeholder="your@email.com" required>
        <button type="submit">Get Started</button>
      </form>
    </section>

    <section class="description">
      <p>${CFG_DESC}</p>
    </section>

    <section class="features">
      <h2>What you get</h2>
      <ul>
${FEATURES_HTML}
      </ul>
    </section>
${TESTIMONIAL_HTML}
    <footer class="footer">
      <p>Questions? <a href="mailto:${CFG_EMAIL}">${CFG_EMAIL}</a></p>
      <p style="margin-top: 8px;">Powered by teebot 🐣</p>
    </footer>
  </div>
</body>
</html>
HTMLEOF

info "✓ Landing page generated: $OUTPUT_FILE"
info "  Name: $CFG_NAME"
info "  Price: \$$CFG_PRICE$CFG_PRICE_LABEL"
info "  Frequency: $CFG_FREQUENCY"

WORD_COUNT=$(echo "$CFG_DESC" | wc -w)
FILE_SIZE=$(wc -c < "$OUTPUT_FILE")
info "  Description: $WORD_COUNT words"
info "  File size: $FILE_SIZE bytes"
