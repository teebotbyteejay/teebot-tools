#!/usr/bin/env bash
# research-synth — cross-paper synthesis for research questions
# Searches graph memory + saved paper extractions, then synthesizes a comparative answer
# Usage: research-synth "How do X and Y differ in their approach to Z?"
set -euo pipefail

WORKSPACE="${WORKSPACE:-$HOME/.openclaw/workspace}"
PAPERS_DIR="$WORKSPACE/memory/papers"
QUERY="${1:-}"
[[ -z "$QUERY" ]] && { echo "Usage: research-synth \"<research question>\"" >&2; exit 1; }

C_RESET='\033[0m'; C_BOLD='\033[1m'; C_DIM='\033[2m'
C_CYAN='\033[36m'; C_GREEN='\033[32m'

echo -e "${C_BOLD}🔬 Research Synthesis${C_RESET}" >&2
echo -e "${C_DIM}Query: $QUERY${C_RESET}" >&2

# --- 1. Graph search for relevant papers/entities ---
echo -e "${C_DIM}[1/3] Searching graph memory...${C_RESET}" >&2
GRAPH_RESULTS=""
if command -v graphmem-sqlite &>/dev/null; then
  GRAPH_RESULTS=$(graphmem-sqlite search "$QUERY" --limit 10 2>/dev/null || true)
fi

# --- 2. Find relevant paper JSONs ---
echo -e "${C_DIM}[2/3] Searching paper extractions...${C_RESET}" >&2
PAPER_CONTEXT=""
if [[ -d "$PAPERS_DIR" ]]; then
  # Search paper titles and extracted content for query terms
  # Extract key terms from query (remove common words)
  TERMS=$(echo "$QUERY" | tr '[:upper:]' '[:lower:]' | tr -s ' ' '\n' | grep -vwE 'how|do|does|the|a|an|in|of|to|and|or|is|are|what|which|their|for|with|from|between|compare|differ|approach' | head -8)
  
  for paper_file in "$PAPERS_DIR"/*.json; do
    [[ -f "$paper_file" ]] || continue
    paper_text=$(cat "$paper_file")
    match=false
    while IFS= read -r term; do
      [[ -z "$term" ]] && continue
      if echo "$paper_text" | grep -qi "$term"; then
        match=true
        break
      fi
    done <<< "$TERMS"
    
    if $match; then
      title=$(echo "$paper_text" | jq -r '.title // "unknown"')
      arxiv_id=$(echo "$paper_text" | jq -r '.arxiv_id // "unknown"')
      extracted=$(echo "$paper_text" | jq -r '.extracted // {}')
      
      PAPER_CONTEXT+="
### ${title} (arxiv:${arxiv_id})
$(echo "$extracted" | jq -r '
"**Techniques:** " + (.key_techniques // [] | join("; ")) + "\n" +
"**Findings:** " + (.key_findings // [] | join("; ")) + "\n" +
"**Benchmarks:** " + (.benchmarks_used // [] | join(", ")) + "\n" +
"**Compared to:** " + (.compared_to // [] | join(", ")) + "\n" +
"**Limitations:** " + (.limitations // [] | join("; "))
')"
    fi
  done
fi

# --- 3. Also search daily logs for manual paper analyses ---
RAW_LOG_CONTEXT=""
ICLR_DOC="$WORKSPACE/docs/iclr2026-memory-papers.md"
if [[ -f "$ICLR_DOC" ]]; then
  # Check if relevant
  if echo "$QUERY" | grep -qiE "MEM1|MemAgent|MemGen|memory|compression|consolidat"; then
    RAW_LOG_CONTEXT=$(head -200 "$ICLR_DOC")
  fi
fi

# --- 4. LLM synthesis ---
echo -e "${C_DIM}[3/3] Synthesizing cross-paper answer...${C_RESET}" >&2

SYSTEM_PROMPT='You are a research synthesis engine for an AI agent. Given a question, graph memory context, and structured paper extractions, produce a COMPARATIVE analysis.

CRITICAL RULES:
1. COMPARE papers side-by-side. Do NOT summarize each paper separately then add a bland conclusion.
2. Structure by DIMENSION (technique type, performance, approach), not by paper.
3. Use specific numbers from findings. No vague "outperforms existing methods."
4. Identify: what is SHARED across papers, what is UNIQUE to each, what is MISSING from all.
5. End with: "For my system (teebot/graphmem-sqlite): [specific actionable implication]"
6. Use precise terminology from the papers. Do not paraphrase technical terms into vague language.
7. Be concise: 200-400 words. Dense, not padded.'

USER_PROMPT="Question: $QUERY

## Graph Memory Results
$GRAPH_RESULTS

## Structured Paper Extractions
${PAPER_CONTEXT:-"(no matching papers found in local store)"}

## Additional Context
${RAW_LOG_CONTEXT:+"$RAW_LOG_CONTEXT"}

Synthesize a comparative answer."

RESPONSE=$(curl -s --max-time 45 "https://api.openai.com/v1/chat/completions" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $OPENAI_API_KEY" \
  -d "$(jq -n \
    --arg sys "$SYSTEM_PROMPT" \
    --arg usr "$USER_PROMPT" \
    '{
      model: "gpt-4o-mini",
      messages: [
        {role: "system", content: $sys},
        {role: "user", content: $usr}
      ],
      max_tokens: 600,
      temperature: 0.3
    }')" 2>/dev/null)

ANSWER=$(echo "$RESPONSE" | jq -r '.choices[0].message.content // empty' 2>/dev/null)

if [[ -z "$ANSWER" ]]; then
  echo -e "${C_RED}Synthesis failed${C_RESET}" >&2
  exit 1
fi

echo -e "\n${C_CYAN}${C_BOLD}Synthesis:${C_RESET}"
echo "$ANSWER"

# Show what papers were used
if [[ -n "$PAPER_CONTEXT" ]]; then
  echo -e "\n${C_DIM}Papers used:${C_RESET}"
  echo "$PAPER_CONTEXT" | grep "^### " | sed 's/^### /  📄 /'
fi
