#!/usr/bin/env bash
# heartbeat-ingest — ingest today's daily log into graphmem-sqlite
# Uses byte-offset tracking to only process NEW content since last ingest.
#
# Usage: heartbeat-ingest [YYYY-MM-DD]
set -euo pipefail

WORKSPACE="${WORKSPACE:-$HOME/.openclaw/workspace}"
DATE="${1:-$(TZ=America/New_York date +%Y-%m-%d)}"

C_RESET='\033[0m'; C_BOLD='\033[1m'; C_DIM='\033[2m'
C_GREEN='\033[32m'; C_CYAN='\033[36m'; C_YELLOW='\033[33m'

if ! command -v graphmem-sqlite &>/dev/null; then
  echo "graphmem-sqlite not found" >&2
  exit 1
fi

# Collect all files matching this date: YYYY-MM-DD.md, YYYY-MM-DD-*.md
LOG_FILES=()
for f in "$WORKSPACE/memory/$DATE"*.md; do
  [[ -f "$f" ]] && LOG_FILES+=("$f")
done

if [[ ${#LOG_FILES[@]} -eq 0 ]]; then
  echo -e "${C_DIM}No files for $DATE${C_RESET}"
  exit 0
fi

# Offset tracking — per-file byte offsets so we only ingest new content
MARKER_DIR="$WORKSPACE/memory/.ingest-markers"
mkdir -p "$MARKER_DIR"
OFFSET_FILE="$MARKER_DIR/$DATE.offsets"

# Load existing offsets (format: filename:byte_offset per line)
declare -A FILE_OFFSETS
if [[ -f "$OFFSET_FILE" ]]; then
  while IFS=: read -r fname offset; do
    [[ -n "$fname" ]] && FILE_OFFSETS["$fname"]="$offset"
  done < "$OFFSET_FILE"
fi

# Collect only NEW content across all files
NEW_CONTENT=""
declare -A NEW_OFFSETS
HAS_NEW=false

for f in "${LOG_FILES[@]}"; do
  fname=$(basename "$f")
  file_size=$(stat -c%s "$f" 2>/dev/null || stat -f%z "$f" 2>/dev/null)
  old_offset=${FILE_OFFSETS["$fname"]:-0}
  
  if [[ $file_size -le $old_offset ]]; then
    # File hasn't grown (or shrunk — reset would catch this)
    NEW_OFFSETS["$fname"]="$old_offset"
    continue
  fi
  
  # Extract only the new bytes
  new_bytes=$((file_size - old_offset))
  if [[ $new_bytes -gt 0 ]]; then
    chunk=$(tail -c +"$((old_offset + 1))" "$f")
    if [[ -n "$chunk" && ${#chunk} -gt 20 ]]; then
      NEW_CONTENT+="--- $fname (new, +${new_bytes} bytes) ---"$'\n'
      NEW_CONTENT+="$chunk"$'\n\n'
      HAS_NEW=true
    fi
  fi
  
  NEW_OFFSETS["$fname"]="$file_size"
done

if [[ "$HAS_NEW" != "true" ]]; then
  echo -e "${C_DIM}No new content for $DATE (${#LOG_FILES[@]} files, all up to date)${C_RESET}"
  exit 0
fi

NEW_SIZE=${#NEW_CONTENT}
echo -e "${C_CYAN}${C_BOLD}Ingesting $DATE — new content: ${NEW_SIZE} chars from ${#LOG_FILES[@]} file(s)${C_RESET}"

if [[ $NEW_SIZE -lt 50 ]]; then
  echo -e "${C_DIM}New content too short ($NEW_SIZE chars), skipping${C_RESET}"
  exit 0
fi

# Split into chunks (~2000 char, section-aware)
CHUNK_SIZE=2000
CHUNKS=()
current_chunk=""

while IFS= read -r line; do
  if [[ "$line" =~ ^## && ${#current_chunk} -gt 200 ]]; then
    CHUNKS+=("$current_chunk")
    current_chunk="$line"$'\n'
  else
    current_chunk+="$line"$'\n'
    if [[ ${#current_chunk} -ge $CHUNK_SIZE ]]; then
      CHUNKS+=("$current_chunk")
      current_chunk=""
    fi
  fi
done <<< "$NEW_CONTENT"

[[ -n "$current_chunk" ]] && CHUNKS+=("$current_chunk")

echo -e "  ${C_DIM}Split into ${#CHUNKS[@]} chunks${C_RESET}"

# Write offsets EARLY — before processing chunks.
# If we get SIGTERM'd mid-extraction, we lose some chunks but avoid
# re-ingesting the same 15KB on every heartbeat (the worse outcome).
: > "$OFFSET_FILE"
for fname in "${!NEW_OFFSETS[@]}"; do
  echo "$fname:${NEW_OFFSETS[$fname]}" >> "$OFFSET_FILE"
done
echo -e "  ${C_DIM}Offsets pre-saved (${#NEW_OFFSETS[@]} files)${C_RESET}"

SUCCESS=0
FAIL=0
for i in "${!CHUNKS[@]}"; do
  chunk="${CHUNKS[$i]}"
  [[ ${#chunk} -lt 50 ]] && continue
  
  if graphmem-sqlite add "Daily log $DATE (delta $((i+1))/${#CHUNKS[@]}): $chunk" 2>/dev/null; then
    SUCCESS=$((SUCCESS + 1))
  else
    FAIL=$((FAIL + 1))
  fi
  sleep 2
done

echo -e "  ${C_GREEN}✓${C_RESET} Ingested $SUCCESS new chunks ($FAIL failed)"

# Report results (offsets already saved above)
if [[ $SUCCESS -gt 0 ]]; then
  echo -e "  ${C_DIM}Offsets confirmed (${SUCCESS} chunks succeeded)${C_RESET}"
else
  echo -e "  ${C_YELLOW}⚠${C_RESET} All chunks failed — offsets were pre-saved, content won't be retried"
  exit 1
fi
