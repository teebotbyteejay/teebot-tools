# Main
# ---------------------------------------------------------------------------

def main():
    args = sys.argv[1:]
    
    if not args or args[0] in ("help", "--help", "-h"):
        print(__doc__)
        sys.exit(0)
    
    cmd = args[0]
    
    if cmd == "analyze":
        days = 7
        for i, a in enumerate(args[1:], 1):
            if a == "--days" and i < len(args):
                days = int(args[i + 1])
        cmd_analyze(days)
    
    elif cmd == "report":
        days = 30
        for i, a in enumerate(args[1:], 1):
            if a == "--days" and i < len(args):
                days = int(args[i + 1])
        cmd_report(days)
    
    elif cmd == "score":
        cmd_score()
    
    elif cmd == "show":
        limit = 10
        for i, a in enumerate(args[1:], 1):
            if a == "--limit" and i < len(args):
                limit = int(args[i + 1])
        cmd_show(limit)
    
    elif cmd == "stats":
        cmd_stats()
    
    else:
        print(f"Unknown command: {cmd}")
        print("Use: flip-tracker help")
        sys.exit(1)


if __name__ == "__main__":
    main()
