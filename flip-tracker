        print(f"\n{icon} #{r[0]} [{r[1][:16]}] {r[3]} (score={r[4]:.1f})")
        print(f"  Pushback ({r[2]}): {r[8]}")
        print(f"  Response: {r[9]}")
        print(f"  Changed: {'YES' if r[5] else 'NO'} | Agreement markers: {r[6]} | Evidence: {'YES' if r[7] else 'NO'}")
    
    conn.close()


def cmd_stats():
    """Show database statistics."""
    init_db()
    conn = get_db()
    
    total = conn.execute("SELECT COUNT(*) FROM flip_events").fetchone()[0]
    sessions = conn.execute("SELECT COUNT(DISTINCT session_key) FROM flip_events").fetchone()[0]
    
    if total == 0:
        print("Database empty. Run: flip-tracker analyze")
        conn.close()
        return
    
    print(f"Flip Tracker Database")
    print(f"  Total events:     {total}")
    print(f"  Sessions scanned: {sessions}")
    
    for cls in ['maintained', 'progressive', 'regressive', 'unclear']:
        count = conn.execute(
            "SELECT COUNT(*) FROM flip_events WHERE classification=?", (cls,)
        ).fetchone()[0]
        print(f"  {cls:12s}:     {count} ({count/total*100:.0f}%)")
    
    oldest = conn.execute("SELECT MIN(ts) FROM flip_events").fetchone()[0]
    newest = conn.execute("SELECT MAX(ts) FROM flip_events").fetchone()[0]
    print(f"  Date range:       {(oldest or 'N/A')[:10]} to {(newest or 'N/A')[:10]}")
    
    conn.close()


