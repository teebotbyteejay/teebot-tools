    """Show recent flip events."""
    init_db()
    conn = get_db()
    
    rows = conn.execute(
        "SELECT id, ts, pushback_type, classification, flip_score, "
        "position_changed, agreement_count, has_evidence, "
        "substr(pushback_text, 1, 70), substr(my_response, 1, 70) "
        "FROM flip_events ORDER BY ts DESC LIMIT ?",
        (limit,)
    ).fetchall()
    
    if not rows:
        print("No flip events. Run: flip-tracker analyze")
