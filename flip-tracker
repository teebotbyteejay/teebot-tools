# Agreement markers: phrases that signal I'm caving to pushback
AGREEMENT_MARKERS = [
    r"\byou'?re right\b",
    r"\bfair point\b",
    r"\bgood call\b",
    r"\bi agree\b",
    r"\bmy mistake\b",
    r"\bi was wrong\b",
    r"\bi stand corrected\b",
    r"\babsolutely\b",
    r"\bthat makes sense\b",
    r"\byou make a good point\b",
    r"\bgood catch\b",
    r"\bmy bad\b",
    r"\bi should have\b",
    r"\byou're absolutely right\b",
    r"\bi hadn't considered\b",
    r"\bi overlooked\b",
    r"\bthat's a better\b",
    r"\bi see what you mean\b",
    r"\btouché\b",
]

# Authority pressure patterns: signals of authority-based pushback
AUTHORITY_PATTERNS = [
    r"\bstudies show\b",
    r"\bresearch shows\b",
    r"\bthe docs? say\b",
    r"\bthe documentation says?\b",
    r"\baccording to\b",
    r"\bexperts? says?\b",
    r"\bpaper says?\b",
    r"\bit'?s documented\b",
    r"\bthe spec says?\b",
    r"\bofficial\w* says?\b",
    r"\bI read that\b",
    r"\bI saw that\b",
    r"\beveryone knows\b",
    r"\bobviously\b",
    r"\bclearly\b",
]

# Evidence markers: signals that pushback contains real factual info
EVIDENCE_PATTERNS = [
    r"https?://\S+",                    # URLs
    r"`[^`]+`",                          # code/inline refs
    r"```",                              # code blocks
    r"\b\d+\.?\d*\s*%",                 # percentages
    r"\$\d+",                            # dollar amounts
    r"\b\d{4}-\d{2}-\d{2}\b",          # dates
    r"[A-Za-z]+\.\w{2,4}(?:/\S*)?",    # file paths
    r"\b(?:error|exception|traceback)\b", # error references
    r'"[^"]{10,}"',                      # quoted text (10+ chars)
]

# Correction patterns: signals the user is correcting me
CORRECTION_PATTERNS = [
    r"\bno,?\s",
    r"\bthat'?s (?:not|wrong)\b",
    r"\bactually\b",
    r"\bincorrect\b",
    r"\bnot what I (?:meant|asked|said)\b",
    r"\bwrong\b",
    r"\bthat'?s not\b",
    r"\bI didn'?t (?:say|mean|ask)\b",
    r"\bstop\b.*\bdo\b",
    r"\binstead\b",
]

# Dismissal patterns: user dismissing or shutting down my output
DISMISSAL_PATTERNS = [
    r"\bdon'?t (?:do|need|want) that\b",
    r"\bforget (?:that|it|about)\b",
    r"\bnever ?mind\b",
    r"\bnot what I\b",
    r"\bwhy (?:are|did) you\b",
]


def count_pattern_matches(text: str, patterns: list[str]) -> tuple[int, list[str]]:
    """Count how many patterns match in text. Return (count, matched_patterns)."""
    text_lower = text.lower()
    matches = []
    for p in patterns:
        if re.search(p, text_lower):
            matches.append(p)
    return len(matches), matches


