#!/usr/bin/env bash
# system-test — automated test suite for core teebot pipeline components
# Catches silent breakage: tool failures, OAuth expiry, pipeline regressions,
# stale state, graphmem corruption.
#
# Usage: system-test              Run all tests
#        system-test --quick      Run only fast tests (< 10 seconds)
#        system-test --benchmark  Run quality benchmarks (mem-test, ~2min)
#        system-test --verbose    Show detailed output
#        system-test <category>   Run specific category: tools, pipeline, memory, infra
#
# Exit code: 0 if all tests pass, 1 if any fail
set -uo pipefail

WORKSPACE="${WORKSPACE:-$HOME/.openclaw/workspace}"
MEMORY_DIR="$WORKSPACE/memory"
TODAY=$(date -u +%Y-%m-%d)
VERBOSE=false
QUICK=false
BENCHMARK=false
REPORT=false
CATEGORY=""

for arg in "$@"; do
  case "$arg" in
    --verbose|-v) VERBOSE=true ;;
    --quick|-q) QUICK=true ;;
    --benchmark|-b) BENCHMARK=true ;;
    --report|-r) REPORT=true ;;
    tools|pipeline|memory|infra|benchmark|behavioral) CATEGORY="$arg" ;;
  esac
done

# "benchmark" category also sets BENCHMARK flag
[[ "$CATEGORY" == "benchmark" ]] && BENCHMARK=true

export PATH="$WORKSPACE/teebot-tools:$WORKSPACE/graphmem:$PATH"

# --- Test Framework ---
PASS=0
FAIL=0
SKIP=0
FAILURES=()

C_RESET='\033[0m'
C_BOLD='\033[1m'
C_GREEN='\033[32m'
C_RED='\033[31m'
C_YELLOW='\033[33m'
C_DIM='\033[2m'

# Verification value tracking: record every check result
declare -A CHECK_RESULTS
HISTORY_FILE="$MEMORY_DIR/system-test-history.jsonl"

# Normalize check names for stable tracking (strip dynamic numbers/details)
normalize_check() {
  echo "$1" | sed -E 's/: .*//; s/ \(.*//; s/[0-9]+[BKGMsmhd]+//g; s/\s+/ /g; s/^ //; s/ $//'
}

pass() { local key; key=$(normalize_check "$1"); ((PASS++)) || true; CHECK_RESULTS["$key"]="pass"; echo -e "  ${C_GREEN}✓${C_RESET} $1"; }
fail() { local key; key=$(normalize_check "$1"); ((FAIL++)) || true; CHECK_RESULTS["$key"]="fail"; FAILURES+=("$1: $2"); echo -e "  ${C_RED}✗${C_RESET} $1 — ${C_DIM}$2${C_RESET}"; }
skip() { local key; key=$(normalize_check "$1"); ((SKIP++)) || true; CHECK_RESULTS["$key"]="skip"; echo -e "  ${C_YELLOW}⊘${C_RESET} $1 — ${C_DIM}$2${C_RESET}"; }

# Dump check results to history
dump_history() {
  local ts
  ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
  local mode="full"
  $QUICK && mode="quick"
  $BENCHMARK && mode="benchmark"
  
  # Build JSON object of results
  local results_json="{"
  local first=true
  for check in "${!CHECK_RESULTS[@]}"; do
    $first || results_json+=","
    first=false
    # Escape check name for JSON
    local escaped_check
    escaped_check=$(printf '%s' "$check" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read()), end='')" 2>/dev/null || printf '"%s"' "$check")
    results_json+="${escaped_check}:\"${CHECK_RESULTS[$check]}\""
  done
  results_json+="}"
  
  echo "{\"timestamp\":\"$ts\",\"mode\":\"$mode\",\"pass\":$PASS,\"fail\":$FAIL,\"skip\":$SKIP,\"results\":$results_json}" >> "$HISTORY_FILE"
}

# Report mode: analyze verification value from history
run_report() {
  echo -e "${C_BOLD}🐣 system-test — Verification Value Report${C_RESET}"
  echo -e "${C_DIM}History: $HISTORY_FILE${C_RESET}\n"
  
  if [[ ! -f "$HISTORY_FILE" ]]; then
    echo "No history yet. Run system-test a few times first."
    exit 0
  fi
  
  local total_runs
  total_runs=$(wc -l < "$HISTORY_FILE")
  echo -e "${C_BOLD}Total runs:${C_RESET} $total_runs\n"
  
  if [[ "$total_runs" -lt 3 ]]; then
    echo "Need at least 3 runs for meaningful analysis."
    exit 0
  fi
  
  # Analyze per-check correction rates using Python for JSON handling
  python3 - "$HISTORY_FILE" << 'PYEOF'
import json, sys
from collections import defaultdict

history_file = sys.argv[1]
check_stats = defaultdict(lambda: {"pass": 0, "fail": 0, "skip": 0, "last_fail": None, "runs": 0})

with open(history_file) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        ts = entry.get("timestamp", "?")
        results = entry.get("results", {})
        for check, result in results.items():
            check_stats[check]["runs"] += 1
            check_stats[check][result] = check_stats[check].get(result, 0) + 1
            if result == "fail":
                check_stats[check]["last_fail"] = ts

# Sort by correction rate (failures / runs), ascending
sorted_checks = sorted(check_stats.items(), key=lambda x: x[1]["fail"] / max(x[1]["runs"], 1))

# Header
print(f"{'Check':<40} {'Runs':>5} {'Fail':>5} {'Rate':>7} {'Last Fail':<12} {'Recommendation'}")
print("-" * 100)

weekly_candidates = []
for check, stats in sorted_checks:
    runs = stats["runs"]
    fails = stats["fail"]
    rate = (fails / runs * 100) if runs > 0 else 0
    last_fail = stats["last_fail"] or "never"
    if last_fail != "never":
        last_fail = last_fail[:10]  # Just the date
    
    # Recommendation logic
    if runs >= 10 and rate == 0:
        rec = "→ weekly"
        weekly_candidates.append(check)
    elif runs >= 5 and rate < 2:
        rec = "→ weekly (likely)"
    elif rate > 10:
        rec = "⚠ keep (high correction value)"
    else:
        rec = "keep"
    
    # Color coding
    if rate == 0:
        rate_str = f"\033[2m{rate:6.1f}%\033[0m"
    elif rate < 5:
        rate_str = f"\033[33m{rate:6.1f}%\033[0m"
    else:
        rate_str = f"\033[31m{rate:6.1f}%\033[0m"
    
    print(f"  {check:<38} {runs:>5} {fails:>5} {rate_str} {last_fail:<12} {rec}")

print()
if weekly_candidates:
    print(f"\033[1m{len(weekly_candidates)} checks with 0% correction rate over 10+ runs:\033[0m")
    print("  These have never caught a real bug. Consider moving to weekly.")
    for c in weekly_candidates:
        print(f"  • {c}")
else:
    print("Not enough history yet for weekly recommendations (need 10+ runs per check).")
PYEOF
  
  exit 0
}
section() { echo -e "\n${C_BOLD}$1${C_RESET}"; }

# === TOOL EXISTENCE & EXECUTABILITY ===
test_tools() {
  section "🔧 Tool Existence & Executability"

  local core_tools=(
    pre-task post-task log-conversation heartbeat-ingest
    workspace-status mailcheck nightly-consolidation
    graphmem-sqlite mem-test capability-score
    moltbook-read reflexion-eval eval-examples
    graphmem-consolidate rule-matcher drift-detect
  )

  for tool in "${core_tools[@]}"; do
    if command -v "$tool" &>/dev/null; then
      local tool_path
      tool_path=$(command -v "$tool")
      if [[ -x "$tool_path" ]]; then
        pass "$tool"
      else
        fail "$tool" "exists but not executable"
      fi
    else
      fail "$tool" "not found on PATH"
    fi
  done
}

# === PIPELINE TESTS ===
test_pipeline() {
  section "⚙️  Pipeline Tests"

  # Test 1: graphmem-sqlite responds and has entities
  local entity_count
  entity_count=$(graphmem-sqlite stats 2>/dev/null | grep -oP 'Entities:\s*\K\d+' || echo "0")
  if [[ "$entity_count" -gt 100 ]]; then
    pass "graphmem-sqlite: $entity_count entities"
  elif [[ "$entity_count" -gt 0 ]]; then
    fail "graphmem-sqlite" "only $entity_count entities (expected >100)"
  else
    fail "graphmem-sqlite" "cannot get entity count"
  fi

  # Test 2: graphmem-sqlite search returns results
  local search_result
  search_result=$(graphmem-sqlite search "teebot memory" --limit 3 --no-log 2>/dev/null || echo "")
  if grep -q "score=" <<< "$search_result"; then
    pass "graphmem search: returns scored results"
  else
    fail "graphmem search" "no scored results returned"
  fi

  # Test 3: pre-task — novel task gets refinement loop
  local novel_output
  novel_output=$(pre-task "design a quantum error correction decoder for topological codes" 2>/dev/null || echo "")
  if grep -qi "refinement loop\|novel task\|first principles" <<< "$novel_output"; then
    pass "pre-task novel: injects refinement loop"
  else
    # Check if it just didn't detect as novel
    if grep -qi "similar past" <<< "$novel_output"; then
      skip "pre-task novel" "task matched existing examples (not truly novel for this graph)"
    else
      fail "pre-task novel" "no refinement loop or examples — unexpected output"
    fi
  fi

  # Test 4: pre-task — familiar task gets examples
  if ! $QUICK; then
    local familiar_output
    familiar_output=$(pre-task "build a bash tool for memory retrieval" 2>/dev/null || echo "")
    if grep -qiE "example|past experience|rule|context" <<< "$familiar_output"; then
      pass "pre-task familiar: retrieves context"
    else
      fail "pre-task familiar" "no context retrieved for familiar-type task"
    fi
  fi

  # Test 5: reflexion-eval responds (even with 0 rules)
  local refl_result
  refl_result=$(reflexion-eval match "test task" 2>&1 || echo "ERROR")
  if grep -qiE "matched|rules|no rules" <<< "$refl_result"; then
    local rule_count
    rule_count=$(echo "$refl_result" | grep -oP '\d+(?=\s*rules?\s*matched)' || echo "?")
    pass "reflexion-eval: responds ($rule_count rules)"
  elif grep -qi "error" <<< "$refl_result"; then
    fail "reflexion-eval" "returned error"
  else
    pass "reflexion-eval: responds"
  fi

  # Test 6: eval-examples has embeddings
  if [[ -f "$MEMORY_DIR/eval-embeddings.bin" ]]; then
    local embed_size
    embed_size=$(wc -c < "$MEMORY_DIR/eval-embeddings.bin")
    if [[ "$embed_size" -gt 1000 ]]; then
      pass "eval-embeddings: ${embed_size}B"
    else
      fail "eval-embeddings" "file too small (${embed_size}B)"
    fi
  else
    fail "eval-embeddings" "file missing"
  fi

  # Test 7: drift-detect has snapshots and can parse MEMORY.md
  if command -v drift-detect &>/dev/null; then
    local drift_stats
    drift_stats=$(drift-detect stats 2>/dev/null || echo "")
    if echo "$drift_stats" | grep -q "Snapshots:"; then
      local snap_count
      snap_count=$(echo "$drift_stats" | grep -oP 'Snapshots:\s*\K\d+' || echo "0")
      if [[ "$snap_count" -gt 0 ]]; then
        pass "drift-detect: $snap_count snapshots"
      else
        fail "drift-detect" "no snapshots (run drift-detect snapshot)"
      fi
    else
      fail "drift-detect" "stats command failed"
    fi
  else
    fail "drift-detect" "not found on PATH"
  fi
}

# === MEMORY TESTS ===
test_memory() {
  section "🧠 Memory Tests"

  # Test 1: CURRENT_STATE.md exists and is recent
  if [[ -f "$WORKSPACE/CURRENT_STATE.md" ]]; then
    local state_age
    state_age=$(( $(date +%s) - $(stat -c %Y "$WORKSPACE/CURRENT_STATE.md") ))
    if [[ "$state_age" -lt 172800 ]]; then  # 48 hours
      pass "CURRENT_STATE.md: fresh ($(( state_age / 3600 ))h old)"
    else
      fail "CURRENT_STATE.md" "stale ($(( state_age / 86400 ))d old)"
    fi
  else
    fail "CURRENT_STATE.md" "file missing"
  fi

  # Test 2: MEMORY.md exists and within budget
  if [[ -f "$WORKSPACE/MEMORY.md" ]]; then
    local mem_size
    mem_size=$(wc -c < "$WORKSPACE/MEMORY.md")
    if [[ "$mem_size" -gt 10240 ]]; then
      fail "MEMORY.md" "over 10KB (${mem_size}B — needs pruning, 8KB budget)"
    elif [[ "$mem_size" -lt 500 ]]; then
      fail "MEMORY.md" "suspiciously small (${mem_size}B)"
    else
      pass "MEMORY.md: ${mem_size}B (within budget)"
    fi
  else
    fail "MEMORY.md" "file missing"
  fi

  # Test 3: Today's daily log exists
  # Check both UTC and EST dates
  local est_today
  est_today=$(TZ=America/New_York date +%Y-%m-%d)
  if [[ -f "$MEMORY_DIR/$TODAY.md" ]]; then
    local log_size
    log_size=$(wc -c < "$MEMORY_DIR/$TODAY.md")
    pass "Daily log ($TODAY): ${log_size}B"
    if [[ "$log_size" -gt 50000 ]]; then
      fail "Daily log size" "over 50KB — may cause boot overhead"
    fi
  elif [[ -f "$MEMORY_DIR/$est_today.md" ]]; then
    local log_size
    log_size=$(wc -c < "$MEMORY_DIR/$est_today.md")
    pass "Daily log ($est_today EST): ${log_size}B"
  else
    fail "Daily log" "no log for today ($TODAY or $est_today)"
  fi

  # Test 4: Memchain integrity
  local memchain_file="$WORKSPACE/.memchain.json"
  [[ ! -f "$memchain_file" ]] && memchain_file="$MEMORY_DIR/.memchain.json"
  if [[ -f "$memchain_file" ]]; then
    local chain_entries
    chain_entries=$(python3 -c "import json; print(len(json.load(open('$memchain_file'))['entries']))" 2>/dev/null || echo "0")
    if [[ "$chain_entries" -gt 0 ]]; then
      pass "Memchain: $chain_entries entries"
    else
      fail "Memchain" "0 entries or parse error"
    fi
  else
    skip "Memchain" "no chain file"
  fi

  # Test 5: TOPICS.md exists
  if [[ -f "$WORKSPACE/TOPICS.md" ]]; then
    pass "TOPICS.md exists"
  else
    fail "TOPICS.md" "missing"
  fi

  # Test 6: heartbeat-ingest delta tracking
  local markers_dir="$MEMORY_DIR/.ingest-markers"
  if [[ -d "$markers_dir" ]]; then
    local marker_count
    marker_count=$(find "$markers_dir" -name "*.offsets" | wc -l)
    if [[ "$marker_count" -gt 0 ]]; then
      pass "heartbeat-ingest: delta tracking ($marker_count offset files)"
    else
      fail "heartbeat-ingest" "markers dir exists but no offset files"
    fi
  else
    skip "heartbeat-ingest" "no .ingest-markers directory"
  fi

  # Test 7: File hygiene — no stale files in memory/ root
  local stale_count=0
  for f in "$MEMORY_DIR"/*.md; do
    [[ ! -f "$f" ]] && continue
    local fname=$(basename "$f")
    # Skip daily logs (YYYY-MM-DD.md pattern) and active files
    [[ "$fname" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2} ]] && continue
    [[ "$fname" == "moltbook-log.md" ]] && continue
    local file_age=$(( $(date +%s) - $(stat -c %Y "$f") ))
    if [[ "$file_age" -gt 1209600 ]]; then  # 14 days
      stale_count=$((stale_count + 1))
    fi
  done
  if [[ "$stale_count" -eq 0 ]]; then
    pass "File hygiene: no stale files (>14d) in memory/"
  else
    fail "File hygiene" "$stale_count files in memory/ older than 14 days — archive them"
  fi

  # Test 8: MEMORY.md under 8KB budget
  if [[ -f "$WORKSPACE/MEMORY.md" ]]; then
    local mem_bytes
    mem_bytes=$(wc -c < "$WORKSPACE/MEMORY.md")
    if [[ "$mem_bytes" -le 8192 ]]; then
      pass "MEMORY.md budget: ${mem_bytes}B / 8192B"
    else
      fail "MEMORY.md budget" "${mem_bytes}B exceeds 8KB budget"
    fi
  fi

  # Test 9: No stray project files in workspace root
  local stray_count=0
  for f in "$WORKSPACE"/*.md; do
    [[ ! -f "$f" ]] && continue
    local fname=$(basename "$f")
    case "$fname" in
      AGENTS.md|CURRENT_STATE.md|HEARTBEAT.md|IDENTITY.md|MEMORY.md|MEMORY-ARCHIVE.md|SOUL.md|TOOLS.md|TOPICS.md|USER.md|BOOTSTRAP.md) continue ;;
      *) stray_count=$((stray_count + 1)) ;;
    esac
  done
  if [[ "$stray_count" -eq 0 ]]; then
    pass "Workspace root: clean (no stray .md files)"
  else
    fail "Workspace root" "$stray_count stray .md files — move to projects/ or memory/"
  fi

  # Test 10: Open request staleness — flag requests >48hrs without communication
  if [[ -f "$WORKSPACE/CURRENT_STATE.md" ]]; then
    local stale_requests=0
    local request_section
    request_section=$(sed -n '/^## Teejay.*Open Requests/,/^## /p' "$WORKSPACE/CURRENT_STATE.md" | head -20)
    # Check for active (non-struck-through) requests that mention STATUS but not PAUSED/DONE
    local active_requests
    active_requests=$(echo "$request_section" | grep -c '^\s*[0-9]\+\.\s\+\*\*[^~]' 2>/dev/null || echo "0")
    if [[ "$active_requests" -gt 0 ]]; then
      # Check if CURRENT_STATE was updated in the last 48 hours
      local cs_age
      cs_age=$(( $(date +%s) - $(stat -c %Y "$WORKSPACE/CURRENT_STATE.md") ))
      if [[ "$cs_age" -gt 172800 ]]; then
        fail "Request staleness" "$active_requests open request(s), CURRENT_STATE.md not updated in $(( cs_age / 3600 ))h — message Teejay!"
      else
        pass "Request staleness: $active_requests active, CURRENT_STATE.md fresh"
      fi
    else
      pass "Request staleness: no active open requests"
    fi
  fi

  # Test 11: graphmem edge count sanity
  local edge_count
  edge_count=$(graphmem-sqlite stats 2>/dev/null | grep -oP 'Edges:\s*\K\d+' || echo "0")
  if [[ "$edge_count" -gt 500 ]]; then
    pass "graphmem edges: $edge_count"
  elif [[ "$edge_count" -gt 0 ]]; then
    fail "graphmem edges" "only $edge_count (expected >500)"
  else
    fail "graphmem edges" "cannot get count"
  fi

  # Test 11: epistemic classification — check that classified edges exist
  local stats_output
  stats_output=$(graphmem-sqlite stats 2>/dev/null || echo "")
  local classified_count
  classified_count=$(sqlite3 "$WORKSPACE/graphmem/data/graphmem.db" \
    "SELECT COUNT(*) FROM edges WHERE epistemic_type != 'unknown' AND expired_at IS NULL;" 2>/dev/null || echo "0")
  if [[ "$classified_count" -gt 100 ]]; then
    pass "epistemic classification: $classified_count classified edges"
  elif [[ "$classified_count" -gt 0 ]]; then
    pass "epistemic classification: $classified_count edges (partial — run graphmem-sqlite classify --apply)"
  else
    fail "epistemic classification" "0 classified edges — run graphmem-sqlite classify --apply"
  fi

  # Test 12: confidence_base — beliefs have base confidence for decay tracking
  local base_count
  base_count=$(sqlite3 "$WORKSPACE/graphmem/data/graphmem.db" \
    "SELECT COUNT(*) FROM edges WHERE epistemic_type='belief' AND confidence_base IS NOT NULL AND expired_at IS NULL;" 2>/dev/null || echo "0")
  local belief_count
  belief_count=$(sqlite3 "$WORKSPACE/graphmem/data/graphmem.db" \
    "SELECT COUNT(*) FROM edges WHERE epistemic_type='belief' AND expired_at IS NULL;" 2>/dev/null || echo "0")
  if [[ "$belief_count" -gt 0 && "$base_count" -eq "$belief_count" ]]; then
    pass "belief decay: $base_count/$belief_count beliefs have confidence_base"
  elif [[ "$base_count" -gt 0 ]]; then
    pass "belief decay: $base_count/$belief_count beliefs have confidence_base (partial)"
  else
    fail "belief decay" "no beliefs have confidence_base — run backfill"
  fi
}

# === INFRASTRUCTURE TESTS ===
test_infra() {
  section "🏗️  Infrastructure Tests"

  # Test 1: Gmail OAuth (quick check — try to list, timeout fast)
  if ! $QUICK; then
    local gmail_result
    gmail_result=$(timeout 15 bash -c 'export GOG_KEYRING_PASSWORD=teebot GOG_ACCOUNT=teebot.by.teejay@gmail.com; gog gmail list "is:unread" -a teebot.by.teejay@gmail.com 2>&1' || echo "TIMEOUT_OR_ERROR")
    if grep -qi "error\|expired\|invalid.*grant\|TIMEOUT_OR_ERROR" <<< "$gmail_result"; then
      if grep -qi "TIMEOUT" <<< "$gmail_result"; then
        fail "Gmail OAuth" "timed out (may be expired or slow)"
      else
        fail "Gmail OAuth" "authentication error — needs renewal"
      fi
    else
      pass "Gmail OAuth: working"
    fi
  else
    skip "Gmail OAuth" "skipped in quick mode"
  fi

  # Test 2: OpenAI API key accessible
  if [[ -n "${OPENAI_API_KEY:-}" ]]; then
    pass "OPENAI_API_KEY: set"
  else
    fail "OPENAI_API_KEY" "not set (needed for pre-task distillation, eval-examples)"
  fi

  # Test 3: Context-inject hook exists
  if [[ -f "$HOME/.openclaw/hooks/context-inject/handler.ts" ]]; then
    pass "context-inject hook: installed"
    # Check if it's been writing
    local inject_dir="$WORKSPACE/injected-context"
    if [[ -d "$inject_dir" ]]; then
      local file_count
      file_count=$(find "$inject_dir" -name "*.md" | wc -l)
      if [[ "$file_count" -gt 0 ]]; then
        local newest_age
        _find_ages=$(find "$inject_dir" -name "*.md" -printf '%T@\n' | sort -rn); newest_age=$(head -1 <<< "$_find_ages")
        local age_hrs=$(( ($(date +%s) - ${newest_age%.*}) / 3600 ))
        pass "context-inject: $file_count file(s) (newest: ${age_hrs}h ago)"
      else
        # Empty dir is expected when only heartbeat/cron sessions have run
        # (hook skips simple messages and cron triggers by design)
        pass "context-inject: 0 files (no complex messages recently)"
      fi
    else
      fail "context-inject" "output directory missing"
    fi
  else
    fail "context-inject hook" "not installed"
  fi

  # Test 3b: ragmem health
  local RAGMEM_DB="$WORKSPACE/ragmem/data/ragmem.db"
  if [[ -f "$RAGMEM_DB" ]]; then
    local rag_chunks rag_embedded rag_files rag_short
    rag_chunks=$(sqlite3 "$RAGMEM_DB" "SELECT COUNT(*) FROM chunks;" 2>/dev/null || echo "0")
    rag_embedded=$(sqlite3 "$RAGMEM_DB" "SELECT COUNT(*) FROM chunks WHERE embedding IS NOT NULL;" 2>/dev/null || echo "0")
    rag_files=$(sqlite3 "$RAGMEM_DB" "SELECT COUNT(DISTINCT source_file) FROM chunks;" 2>/dev/null || echo "0")
    rag_short=$(sqlite3 "$RAGMEM_DB" "SELECT COUNT(*) FROM chunks WHERE char_count < 80;" 2>/dev/null || echo "0")
    
    if [[ "$rag_chunks" -eq 0 ]]; then
      fail "ragmem" "database exists but empty — run: ragmem ingest"
    elif [[ "$rag_embedded" -lt "$rag_chunks" ]]; then
      local missing=$((rag_chunks - rag_embedded))
      fail "ragmem embeddings" "$missing/$rag_chunks chunks missing embeddings"
    elif [[ "$rag_short" -gt 5 ]]; then
      fail "ragmem quality" "$rag_short short chunks (<80 chars) — re-ingest"
    else
      # Check freshness: newest file should be today or yesterday
      local newest_date
      newest_date=$(sqlite3 "$RAGMEM_DB" "SELECT MAX(source_date) FROM chunks;" 2>/dev/null || echo "")
      local yesterday
      yesterday=$(date -d "yesterday" +%Y-%m-%d 2>/dev/null || date +%Y-%m-%d)
      if [[ -n "$newest_date" && "$newest_date" < "$yesterday" ]]; then
        fail "ragmem freshness" "newest data is $newest_date — run: ragmem ingest"
      else
        pass "ragmem: $rag_chunks chunks, $rag_files files, newest=$newest_date"
      fi
    fi
  else
    fail "ragmem" "database not found at $RAGMEM_DB"
  fi

  # Test 4: Cron jobs exist
  local cron_count
  cron_count=$(crontab -l 2>/dev/null | grep -c "openclaw\|teebot" || echo "0")
  if [[ "$cron_count" -gt 0 ]]; then
    pass "Cron jobs: $cron_count registered"
  else
    skip "Cron jobs" "no user cron found (may use openclaw scheduler)"
  fi

  # Test 5: Git repos clean (no uncommitted changes in critical repos)
  for repo in "$WORKSPACE" "$WORKSPACE/graphmem"; do
    if [[ -d "$repo/.git" ]]; then
      local repo_name
      repo_name=$(basename "$repo")
      [[ "$repo_name" == "workspace" ]] && repo_name="workspace"
      local uncommitted
      uncommitted=$(cd "$repo" && git status --porcelain 2>/dev/null | wc -l)
      if [[ "$uncommitted" -gt 20 ]]; then
        fail "git:$repo_name" "$uncommitted uncommitted changes (consider committing)"
      else
        pass "git:$repo_name: $uncommitted uncommitted"
      fi
    fi
  done

  # Test 6: Disk space
  local avail_kb
  avail_kb=$(df -k "$WORKSPACE" | tail -1 | awk '{print $4}')
  local avail_gb=$(( avail_kb / 1048576 ))
  if [[ "$avail_kb" -gt 1048576 ]]; then  # > 1GB
    pass "Disk: ${avail_gb}GB available"
  elif [[ "$avail_kb" -gt 524288 ]]; then  # > 512MB
    fail "Disk" "only ${avail_gb}GB available — getting low"
  else
    fail "Disk" "critically low: ${avail_gb}GB"
  fi

  # Test 7: Constitution integrity (SOUL.md, HEARTBEAT.md, AGENTS.md tamper detection)
  local HASH_FILE="$WORKSPACE/.constitution-hashes"
  if [[ -f "$HASH_FILE" ]]; then
    local constitution_ok=true
    for cf in SOUL.md HEARTBEAT.md AGENTS.md; do
      local cf_path="$WORKSPACE/$cf"
      if [[ ! -f "$cf_path" ]]; then
        fail "constitution:$cf" "file missing!"
        constitution_ok=false
        continue
      fi
      local c_hash k_hash
      c_hash=$(sha256sum "$cf_path" | cut -d' ' -f1)
      k_hash=$(grep "  ${cf}\$" "$HASH_FILE" | cut -d' ' -f1)
      if [[ -n "$k_hash" && "$c_hash" != "$k_hash" ]]; then
        fail "constitution:$cf" "hash mismatch — modified since last acceptance"
        constitution_ok=false
      fi
    done
    if [[ "$constitution_ok" == "true" ]]; then
      pass "Constitution integrity: all 3 files verified"
    fi
  else
    fail "constitution" "no hash file — run: workspace-status --accept-constitution"
  fi

  # Test 8: Boot context size
  local total_boot=0
  for f in SOUL.md MEMORY.md HEARTBEAT.md CURRENT_STATE.md TOPICS.md AGENTS.md; do
    if [[ -f "$WORKSPACE/$f" ]]; then
      local fsize
      fsize=$(wc -c < "$WORKSPACE/$f")
      total_boot=$((total_boot + fsize))
    fi
  done
  local boot_kb=$((total_boot / 1024))
  if [[ "$total_boot" -lt 30720 ]]; then  # < 30KB
    pass "Boot context: ${boot_kb}KB (6 files)"
  elif [[ "$total_boot" -lt 51200 ]]; then  # < 50KB
    fail "Boot context" "${boot_kb}KB — consider trimming (30KB target)"
  else
    fail "Boot context" "${boot_kb}KB — too large, degrading performance"
  fi
}

# === BENCHMARK TESTS (quality, not just presence) ===
test_benchmark() {
  section "📏 Quality Benchmarks"

  local benchmark_log="$MEMORY_DIR/benchmark-history.jsonl"

  # Test 1: mem-test --raw-check (retrieval accuracy)
  echo -e "  ${C_DIM}Running mem-test --raw-check (this takes ~60s)...${C_RESET}"
  local memtest_output
  memtest_output=$(timeout 180 mem-test --raw-check 2>/dev/null || echo "TIMEOUT")

  if [[ "$memtest_output" == "TIMEOUT" ]]; then
    fail "mem-test --raw-check" "timed out after 180s"
  else
    # Strip ANSI codes for reliable parsing
    local clean_output
    clean_output=$(echo "$memtest_output" | sed 's/\x1b\[[0-9;]*m//g')
    # Parse score from output: "Score: 52%"
    local score
    score=$(echo "$clean_output" | grep -oP 'Score:\s*\K\d+' || echo "0")
    local passed_count
    passed_count=$(echo "$clean_output" | grep -oP '\K\d+(?= passed)' || echo "0")
    local failed_count
    failed_count=$(echo "$clean_output" | grep -oP '\K\d+(?= failed)' || echo "0")
    local total_count=$((passed_count + failed_count))

    # Load last known baseline
    local baseline=86  # Initial baseline from March 11 measurement
    if [[ -f "$benchmark_log" ]]; then
      local last_score
      last_score=$(tail -1 "$benchmark_log" | python3 -c "import json,sys; print(json.load(sys.stdin).get('retrieval_score', $baseline))" 2>/dev/null || echo "$baseline")
      baseline="$last_score"
    fi

    # Calculate delta
    local delta=$((score - baseline))
    local delta_str=""
    if [[ "$delta" -gt 0 ]]; then
      delta_str=" (${C_GREEN}+${delta}${C_RESET} from baseline ${baseline}%)"
    elif [[ "$delta" -lt 0 ]]; then
      delta_str=" (${C_RED}${delta}${C_RESET} from baseline ${baseline}%)"
    else
      delta_str=" (unchanged from baseline ${baseline}%)"
    fi

    if [[ "$score" -ge 75 ]]; then
      pass "Retrieval accuracy: ${score}% ($passed_count/$total_count)${delta_str}"
    elif [[ "$score" -ge 50 ]]; then
      fail "Retrieval accuracy" "${score}% ($passed_count/$total_count) — below 75% threshold${delta_str}"
    else
      fail "Retrieval accuracy" "${score}% ($passed_count/$total_count) — critically low${delta_str}"
    fi

    # Record to benchmark history
    local timestamp
    timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    local est_date
    est_date=$(TZ=America/New_York date +%Y-%m-%d)
    echo "{\"date\":\"$est_date\",\"timestamp\":\"$timestamp\",\"retrieval_score\":$score,\"passed\":$passed_count,\"failed\":$failed_count,\"total\":$total_count,\"baseline\":$baseline,\"delta\":$delta}" >> "$benchmark_log"

    # Show failures if verbose or score dropped
    if [[ "$delta" -lt -5 ]] || $VERBOSE; then
      local failures
      failures=$(echo "$memtest_output" | grep "FAIL" || true)
      if [[ -n "$failures" ]]; then
        echo -e "  ${C_DIM}Failures:${C_RESET}"
        echo "$failures" | while read -r line; do
          echo -e "    ${C_RED}•${C_RESET} ${C_DIM}$line${C_RESET}"
        done
      fi
    fi

    # Alert on significant regression (>10 point drop)
    if [[ "$delta" -le -10 ]]; then
      echo -e "\n  ${C_RED}${C_BOLD}⚠ REGRESSION ALERT: Retrieval score dropped ${delta} points!${C_RESET}"
      echo -e "  ${C_DIM}Likely cause: MEMORY.md consolidation trimmed critical facts.${C_RESET}"
      echo -e "  ${C_DIM}Action: check MEMORY.md diff, restore essential Key Findings.${C_RESET}"
    fi
  fi

  # Test 2: graphmem search relevance (spot check with known good queries)
  local relevance_pass=0
  local relevance_total=0

  # Known queries with expected high-relevance results
  declare -A relevance_checks=(
    ["Kuzu segfault migration"]="SQLite|kuzu|270"
    ["reflexion rules pruned platitudes"]="70|platitude|prune"
    ["Shujaat research DCEGM"]="Shujaat|DCEGM|Mississauga"
  )

  for query in "${!relevance_checks[@]}"; do
    relevance_total=$((relevance_total + 1))
    local expected_terms="${relevance_checks[$query]}"
    local search_result
    search_result=$(graphmem-sqlite search "$query" --limit 5 --no-log 2>/dev/null || echo "")

    local found_any=false
    IFS='|' read -ra terms <<< "$expected_terms"
    for term in "${terms[@]}"; do
      if grep -qi "$term" <<< "$search_result"; then
        found_any=true
        break
      fi
    done

    if $found_any; then
      relevance_pass=$((relevance_pass + 1))
    fi
  done

  if [[ "$relevance_pass" -eq "$relevance_total" ]]; then
    pass "graphmem relevance: ${relevance_pass}/${relevance_total} spot checks"
  elif [[ "$relevance_pass" -gt 0 ]]; then
    fail "graphmem relevance" "${relevance_pass}/${relevance_total} — some queries returning irrelevant results"
  else
    fail "graphmem relevance" "0/${relevance_total} — search appears broken"
  fi
}

# === BEHAVIORAL TESTS (verify correct system behavior, not just existence) ===
test_behavioral() {
  section "🧠 Behavioral Tests"
  
  local SESSIONS_DIR="$HOME/.openclaw/agents/main/sessions"
  local TEEJAY_NUM="+18029896729"
  
  # --- Test 1: Message target audit ---
  # Scan recent sessions for message sends to non-Teejay targets
  # This catches the March 10 credential leak and March 14 routing incident class of bugs
  local violations=0
  local total_sends=0
  local violation_details=""
  
  if [[ -d "$SESSIONS_DIR" ]]; then
    # Check session files modified in last 48 hours for message sends
    local recent_files
    recent_files=$(find "$SESSIONS_DIR" -name "*.jsonl" -mtime -2 2>/dev/null | head -50)
    
    while IFS= read -r session_file; do
      [[ -z "$session_file" ]] && continue
      
      # Extract message send tool calls — look for "action":"send" with target field
      # Format: {"toolName":"message", ...arguments containing action and target...}
      local sends
      sends=$(grep -o '"toolName":"message"[^}]*' "$session_file" 2>/dev/null | head -50 || true)
      
      # Also check the actual tool call arguments for targets
      # Look for lines containing message tool calls with send action
      local send_lines
      send_lines=$(grep '"message"' "$session_file" 2>/dev/null | grep -i '"send"' | head -50 || true)
      
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        total_sends=$((total_sends + 1))
        
        # Extract target from the line
        local target
        target=$(echo "$line" | grep -oP '"target"\s*:\s*"[^"]*"' | head -1 || true)
        
        if [[ -n "$target" ]]; then
          # Check if target is Teejay's number
          if ! echo "$target" | grep -q "$TEEJAY_NUM"; then
            # Check if it's an internal/system target (no phone number pattern)
            if echo "$target" | grep -qP '\+\d{10,}'; then
              violations=$((violations + 1))
              local session_name
              session_name=$(basename "$session_file" .jsonl)
              violation_details+="  target=$target in session=${session_name:0:16}\n"
            fi
          fi
        fi
      done <<< "$send_lines"
    done <<< "$recent_files"
    
    if [[ "$violations" -gt 0 ]]; then
      fail "message target audit" "$violations messages to non-Teejay targets in last 48h"
      echo -e "  ${C_RED}Violations:${C_RESET}"
      echo -e "$violation_details" | head -10
    elif [[ "$total_sends" -gt 0 ]]; then
      pass "message target audit: $total_sends sends, all to Teejay ($TEEJAY_NUM)"
    else
      pass "message target audit: no message sends found in last 48h"
    fi
  else
    skip "message target audit" "sessions directory not found"
  fi
  
  # --- Test 2: Prediction log staleness ---
  # Check if any predictions are past their resolution date and unresolved
  local pred_log="$MEMORY_DIR/prediction-log.jsonl"
  
  if [[ -f "$pred_log" ]]; then
    local today_iso
    today_iso=$(date +%Y-%m-%d)
    local total_predictions=0
    local overdue=0
    local resolved=0
    local overdue_details=""
    
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      total_predictions=$((total_predictions + 1))
      
      local res_date
      res_date=$(echo "$line" | python3 -c "import json,sys; print(json.load(sys.stdin).get('resolution_date',''))" 2>/dev/null || echo "")
      local is_resolved
      is_resolved=$(echo "$line" | python3 -c "import json,sys; d=json.load(sys.stdin); print('yes' if d.get('resolved') or d.get('outcome') else 'no')" 2>/dev/null || echo "no")
      
      if [[ "$is_resolved" == "yes" ]]; then
        resolved=$((resolved + 1))
      elif [[ -n "$res_date" && "$res_date" < "$today_iso" ]]; then
        overdue=$((overdue + 1))
        local pred_summary
        pred_summary=$(echo "$line" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('prediction','')[:60])" 2>/dev/null || echo "")
        overdue_details+="    due=$res_date: $pred_summary\n"
      fi
    done < "$pred_log"
    
    if [[ "$overdue" -gt 0 ]]; then
      fail "prediction log" "$overdue/$total_predictions predictions overdue for resolution"
      echo -e "$overdue_details"
    elif [[ "$total_predictions" -gt 0 ]]; then
      pass "prediction log: $total_predictions predictions ($resolved resolved, 0 overdue)"
    else
      pass "prediction log: exists (empty — make predictions!)"
    fi
  else
    pass "prediction log: no log yet"
  fi
  
  # --- Test 3: Graph quality baseline ---
  # After pruning, monitor that graph quality doesn't degrade
  local DB="$WORKSPACE/graphmem/data/graphmem.db"
  
  if [[ -f "$DB" ]]; then
    local active_edges
    active_edges=$(sqlite3 "$DB" "SELECT COUNT(*) FROM edges WHERE expired_at IS NULL;" 2>/dev/null || echo "0")
    local never_retrieved
    never_retrieved=$(sqlite3 "$DB" "SELECT COUNT(*) FROM edges WHERE expired_at IS NULL AND retrieval_count = 0;" 2>/dev/null || echo "0")
    local dead_edges
    dead_edges=$(sqlite3 "$DB" "SELECT COUNT(*) FROM edges WHERE expired_at IS NULL AND activation < -1.35 AND retrieval_count = 0;" 2>/dev/null || echo "0")
    local short_facts
    short_facts=$(sqlite3 "$DB" "SELECT COUNT(*) FROM edges WHERE expired_at IS NULL AND length(fact) < 30;" 2>/dev/null || echo "0")
    
    # Calculate never-retrieved ratio
    local never_ratio=0
    if [[ "$active_edges" -gt 0 ]]; then
      never_ratio=$((never_retrieved * 100 / active_edges))
    fi
    
    # Graph quality checks
    if [[ "$dead_edges" -gt 50 ]]; then
      fail "graph quality: dead edges" "$dead_edges dead edges (activation<-1.35, unretrieved) — run graph-prune --apply"
    elif [[ "$short_facts" -gt 20 ]]; then
      fail "graph quality: short facts" "$short_facts edges with fact < 30 chars — quality gate may be disabled"
    else
      pass "graph quality: ${active_edges} active edges, ${dead_edges} dead, ${short_facts} short facts"
    fi
  else
    skip "graph quality" "graphmem database not found"
  fi
  
  # --- Test 4: Feedback signal freshness ---
  # Check that human feedback is being captured
  local fb_log="$MEMORY_DIR/feedback-log.jsonl"
  
  if [[ -f "$fb_log" ]]; then
    local fb_count
    fb_count=$(wc -l < "$fb_log" 2>/dev/null || echo "0")
    local recent_fb
    recent_fb=$(tail -5 "$fb_log" 2>/dev/null | python3 -c "
import sys, json
from datetime import datetime, timedelta
cutoff = (datetime.utcnow() - timedelta(days=7)).strftime('%Y-%m-%d')
recent = 0
for line in sys.stdin:
    try:
        d = json.loads(line)
        if d.get('date','') >= cutoff: recent += 1
    except: pass
print(recent)
" 2>/dev/null || echo "0")
    
    if [[ "$fb_count" -gt 0 ]]; then
      pass "feedback capture: $fb_count entries ($recent_fb in last 7d)"
    else
      pass "feedback capture: log exists (empty — capture Teejay's reactions!)"
    fi
  else
    pass "feedback capture: no log yet (build with log-feedback)"
  fi
  
  # --- Test 4b: Coactive preference store ---
  local coactive_db="$MEMORY_DIR/coactive.db"
  
  if [[ -f "$coactive_db" ]]; then
    local coactive_total
    coactive_total=$(sqlite3 "$coactive_db" "SELECT COUNT(*) FROM preferences;" 2>/dev/null || echo "0")
    local coactive_types
    coactive_types=$(sqlite3 "$coactive_db" "SELECT signal_type || ':' || COUNT(*) FROM preferences GROUP BY signal_type ORDER BY COUNT(*) DESC;" 2>/dev/null | tr '\n' ', ' | sed 's/,$//' || echo "?")
    
    if [[ "$coactive_total" -eq 0 ]]; then
      fail "coactive preferences" "database exists but empty — run: coactive extract"
    else
      pass "coactive preferences: $coactive_total pairs ($coactive_types)"
    fi
  else
    skip "coactive preferences" "not yet extracted — run: coactive extract"
  fi
  
  # --- Test 4c: Position flip tracker (sycophancy monitoring) ---
  local flip_db="$MEMORY_DIR/flip-tracker.db"
  
  if [[ -f "$flip_db" ]]; then
    local flip_total
    flip_total=$(sqlite3 "$flip_db" "SELECT COUNT(*) FROM flip_events;" 2>/dev/null || echo "0")
    local flip_regressive
    flip_regressive=$(sqlite3 "$flip_db" "SELECT COUNT(*) FROM flip_events WHERE classification='regressive';" 2>/dev/null || echo "0")
    local flip_maintained
    flip_maintained=$(sqlite3 "$flip_db" "SELECT COUNT(*) FROM flip_events WHERE classification='maintained';" 2>/dev/null || echo "0")
    
    if [[ "$flip_total" -gt 0 ]]; then
      local regressive_pct=$((flip_regressive * 100 / flip_total))
      if [[ "$regressive_pct" -gt 30 ]]; then
        fail "flip tracker" "regressive rate ${regressive_pct}% (${flip_regressive}/${flip_total}) — sycophancy risk HIGH"
      else
        pass "flip tracker: ${flip_total} events, ${flip_maintained} maintained, ${flip_regressive} regressive (${regressive_pct}%)"
      fi
    else
      pass "flip tracker: database exists but no events — run: flip-tracker analyze"
    fi
  else
    skip "flip tracker" "not yet initialized — run: flip-tracker analyze"
  fi
  
  # --- Test 5: Post-task evaluation distribution ---
  # Check that we're not just getting confirmatory high scores
  local eval_dir="$MEMORY_DIR/reflexion-evals"
  
  if [[ -d "$eval_dir" ]]; then
    local eval_count
    eval_count=$(ls "$eval_dir"/*.json 2>/dev/null | wc -l || echo "0")
    
    if [[ "$eval_count" -ge 10 ]]; then
      # Analyze score distribution (scores live in evaluation.score or top-level score)
      local score_stats
      score_stats=$(ls -t "$eval_dir"/*.json 2>/dev/null | head -30 | while read -r f; do
        python3 -c "
import json
d=json.load(open('$f'))
s = d.get('score') or (d.get('evaluation',{}) or {}).get('score')
if s is not None: print(int(s))
" 2>/dev/null || true
      done | python3 -c "
import sys
scores = [int(s.strip()) for s in sys.stdin if s.strip().isdigit()]
if scores:
    avg = sum(scores)/len(scores)
    high = sum(1 for s in scores if s >= 80)
    low = sum(1 for s in scores if s < 60)
    total = len(scores)
    high_pct = high * 100 // total
    print(f'{avg:.0f} avg | {high}/{total} ≥80 ({high_pct}%) | {low}/{total} <60')
else:
    print('no scored evals')
" 2>/dev/null || echo "parse error")
      
      # If >90% of scores are ≥80, self-eval is probably overconfident
      local high_pct
      high_pct=$(echo "$score_stats" | grep -oP '\((\d+)%\)' | grep -oP '\d+' || echo "0")
      
      if [[ "$high_pct" -gt 90 ]]; then
        fail "eval distribution" "self-eval likely overconfident: $score_stats (>90% high scores)"
      else
        pass "eval distribution: $score_stats (recent $eval_count evals)"
      fi
    elif [[ "$eval_count" -gt 0 ]]; then
      pass "eval distribution: $eval_count evals (need 10+ for distribution check)"
    else
      pass "eval distribution: no evals yet"
    fi
  else
    skip "eval distribution" "eval directory not found"
  fi
}

